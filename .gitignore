# === ignore all the data files ===
*.csv
*txt

# === Python Operating Cache ===
__pycache__/
*.py[cod]
*$py.class

# === Virtual Environments (Crucial to ignore) ===
.venv/
venv/
ENV/
env/
ENV/

# === IDE Configurations ===
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# === Distribution / Packaging ===
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# === Testing and Coverage ===
.htmlcov/
.tox/
.nosetox/
.pytest_cache/
.mypy_cache/
htmlcov/
coverage.xml
*.cover
*.py,cover

# === Environment Variables / Secrets (Never commit these!) ===
.env
.env.*
secrets.json
credentials.json

# === Data and Logs ===
*.log
*.sqlite3
